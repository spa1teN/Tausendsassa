# Tausendsassa Discord Bot Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED CONFIGURATION
# ===========================================

# Discord Bot Token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Database Password (required for Docker deployment)
DB_PASSWORD=your_secure_database_password_here

# Optional Bot Configuration
BOT_OWNER_ID=485051896655249419
GUILD_ID=your_main_guild_id_here

# Logging Configuration
LOG_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
LOG_LEVEL=INFO

# Backup Configuration
BACKUP_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_BACKUP_WEBHOOK_ID/YOUR_BACKUP_WEBHOOK_TOKEN

# RSS Feed Configuration
RSS_POLL_INTERVAL_MINUTES=1.0
RSS_MAX_POST_AGE_SECONDS=86400
RSS_RATE_LIMIT_SECONDS=30
RSS_FAILURE_THRESHOLD=3
RSS_MAX_RETRIES=3
RSS_BASE_RETRY_DELAY=2.0
AUTHORIZED_USERS=485051896655249419,506551160354766848,703896034820096000
GLOBAL_MONITOR_CHANNEL_ID=your_monitor_channel_id_here

# Map Configuration
MAP_PIN_COOLDOWN_MINUTES=30

# Cache Configuration
MAX_CACHE_SIZE_MB=100
MAX_MEMORY_CACHE_ITEMS=50

# HTTP Configuration
HTTP_TIMEOUT=30
MAX_HTTP_CONNECTIONS=100
MAX_HTTP_CONNECTIONS_PER_HOST=10

# Monitor Configuration
MONITOR_AUTHORIZED_ROLES=1402526603057303653,1398500235541610639
SYSTEM_METRICS_INTERVAL=60
MONITOR_UPDATE_INTERVAL=300

# ===========================================
# WEB ADMIN PANEL (webapp)
# ===========================================

# Discord OAuth2 (same Application as the bot — add redirect URI in Discord Dev Portal)
# Redirect URI to add: https://your-domain.de/auth/callback
DISCORD_CLIENT_ID=your_discord_application_id_here
DISCORD_CLIENT_SECRET=your_discord_oauth2_secret_here

# Session signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBAPP_SECRET_KEY=your_random_secret_key_here

# Public URL of the web panel (no trailing slash)
# Used by the webapp itself (OAuth2 redirect URI) AND by the bot (Explore button URL)
WEBAPP_BASE_URL=https://tausendsassa.your-domain.de
WEBAPP_URL=https://tausendsassa.your-domain.de

# ===========================================
# TEST SERVER
# ===========================================

# Guild ID of the designated test server for early feature rollout.
# New features (e.g. OSM map system) are enabled here first before global rollout.
TEST_GUILD_ID=your_test_server_id_here

# ===========================================
# DATABASE CONFIGURATION (Docker)
# ===========================================

# Database connection settings (defaults work with docker-compose)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=tausendsassa
DB_USER=tausendsassa
# DB_PASSWORD is set above in Required Configuration
